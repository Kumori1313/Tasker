<Window x:Class="UniversalTasker.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UniversalTasker.UI.ViewModels"
        xmlns:svc="clr-namespace:UniversalTasker.UI.Services"
        Title="Universal Tasker" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewWorkflowCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding LoadWorkflowCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveWorkflowCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveWorkflowAsCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewWorkflowCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding LoadWorkflowCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveWorkflowCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveWorkflowAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="Export as _PowerShell Script..." Command="{Binding ExportAsPowerShellCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Add Action">
                    <MenuItem Header="Input">
                        <MenuItem Header="Mouse Click" Command="{Binding AddMouseClickCommand}"/>
                        <MenuItem Header="Key Press" Command="{Binding AddKeyPressCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Flow Control">
                        <MenuItem Header="Delay" Command="{Binding AddDelayCommand}"/>
                        <Separator/>
                        <MenuItem Header="If/Else" Command="{Binding AddConditionCommand}"/>
                        <MenuItem Header="Repeat" Command="{Binding AddRepeatCommand}"/>
                        <MenuItem Header="While Loop" Command="{Binding AddWhileCommand}"/>
                        <Separator/>
                        <MenuItem Header="Break" Command="{Binding AddBreakCommand}"/>
                        <MenuItem Header="Continue" Command="{Binding AddContinueCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Variables">
                        <MenuItem Header="Set Variable" Command="{Binding AddSetVariableCommand}"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Add Trigger">
                    <MenuItem Header="Timer" Command="{Binding AddTimerTriggerCommand}"/>
                    <MenuItem Header="File System" Command="{Binding AddFileSystemTriggerCommand}"/>
                    <MenuItem Header="Hotkey" Command="{Binding AddHotkeyTriggerCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Remove Action" Command="{Binding RemoveActionCommand}"/>
                <MenuItem Header="Remove Trigger" Command="{Binding RemoveTriggerCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Show _Log Panel" IsCheckable="True"
                          IsChecked="{Binding IsLogPanelVisible}"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="_Start" Command="{Binding StartCommand}"/>
                <MenuItem Header="S_top" Command="{Binding StopCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Padding="4">
            <Button Content="Undo" Command="{Binding UndoCommand}" Padding="8,2" ToolTip="Undo (Ctrl+Z)"/>
            <Button Content="Redo" Command="{Binding RedoCommand}" Padding="8,2" ToolTip="Redo (Ctrl+Y)"/>
            <Separator/>
            <Menu Background="Transparent">
                <MenuItem Header="Add Action">
                    <MenuItem Header="Input">
                        <MenuItem Header="Mouse Click" Command="{Binding AddMouseClickCommand}"/>
                        <MenuItem Header="Key Press" Command="{Binding AddKeyPressCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Flow Control">
                        <MenuItem Header="Delay" Command="{Binding AddDelayCommand}"/>
                        <Separator/>
                        <MenuItem Header="If/Else" Command="{Binding AddConditionCommand}"/>
                        <MenuItem Header="Repeat" Command="{Binding AddRepeatCommand}"/>
                        <MenuItem Header="While Loop" Command="{Binding AddWhileCommand}"/>
                        <Separator/>
                        <MenuItem Header="Break" Command="{Binding AddBreakCommand}"/>
                        <MenuItem Header="Continue" Command="{Binding AddContinueCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Variables">
                        <MenuItem Header="Set Variable" Command="{Binding AddSetVariableCommand}"/>
                    </MenuItem>
                </MenuItem>
            </Menu>
            <Separator/>
            <Button Content="Remove" Command="{Binding RemoveActionCommand}" Padding="8,2"/>
            <Separator/>
            <Button Content="Move Up" Command="{Binding MoveUpCommand}" Padding="8,2"/>
            <Button Content="Move Down" Command="{Binding MoveDownCommand}" Padding="8,2"/>
            <Separator/>
            <Button Content="Start" Command="{Binding StartCommand}" Padding="12,2"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Padding="12,2"
                    Background="#f44336" Foreground="White"/>
        </ToolBar>

        <!-- Hotkey Settings Panel -->
        <Expander Grid.Row="2" Header="Hotkey Settings" Margin="8,4,8,0" IsExpanded="False">
            <Border Background="#FAFAFA" Padding="12" CornerRadius="4">
                <StackPanel>
                    <!-- Capturing indicator -->
                    <TextBlock Text="{Binding CapturingHotkeyLabel}"
                               Foreground="#0078D4" FontWeight="SemiBold" Margin="0,0,0,8"
                               Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BoolToVis}}"/>

                    <!-- Same/Different hotkey toggle -->
                    <CheckBox Content="Use same hotkey to Start/Stop (toggle mode)"
                              IsChecked="{Binding UseSameHotkey}" Margin="0,0,0,12"/>

                    <!-- Start Hotkey -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Start Hotkey:"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseSameHotkey}" Value="True">
                                            <Setter Property="Text" Value="Toggle Hotkey:"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border Grid.Column="1" Background="White" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding StartHotkey.DisplayText}" FontFamily="Consolas"/>
                        </Border>
                        <Button Grid.Column="2" Content="Set" Command="{Binding SetStartHotkeyCommand}"
                                Padding="12,4" Margin="0,0,4,0"/>
                        <Button Grid.Column="3" Content="Clear" Command="{Binding ClearStartHotkeyCommand}"
                                Padding="8,4"/>
                    </Grid>

                    <!-- Stop Hotkey (only visible when not using same hotkey) -->
                    <Grid Margin="0,0,0,8" Visibility="{Binding ShowSeparateStopHotkey, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Stop Hotkey:" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="White" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding StopHotkey.DisplayText}" FontFamily="Consolas"/>
                        </Border>
                        <Button Grid.Column="2" Content="Set" Command="{Binding SetStopHotkeyCommand}"
                                Padding="12,4" Margin="0,0,4,0"/>
                        <Button Grid.Column="3" Content="Clear" Command="{Binding ClearStopHotkeyCommand}"
                                Padding="8,4"/>
                    </Grid>

                    <TextBlock Text="Press Escape to cancel while setting a hotkey"
                               FontSize="11" Foreground="Gray" FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </Expander>

        <!-- Main Content -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Action List -->
            <GroupBox Grid.Column="0" Header="Actions" Margin="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" FontSize="11" Foreground="Gray"
                               Margin="4" TextWrapping="Wrap">
                        Tip: Drag actions to reorder. Select a container to add child actions inside it.
                    </TextBlock>
                    <ListBox ItemsSource="{Binding Actions}"
                             SelectedItem="{Binding SelectedAction}"
                             HorizontalContentAlignment="Stretch"
                             svc:ListBoxDragDropBehavior.IsEnabled="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="4" Margin="0,0,8,0" CornerRadius="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Category}" Value="Flow">
                                                            <Setter Property="Background" Value="#2196F3"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Variables">
                                                            <Setter Property="Background" Value="#9C27B0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Input">
                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Foreground="Gray">
                                                <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Category, Mode=OneWay, StringFormat='[{0}]'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Triggers & Variables -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Triggers List -->
                <GroupBox Grid.Row="0" Header="Triggers" Margin="4,8,4,4">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                            <Button Content="+" Command="{Binding AddTimerTriggerCommand}"
                                    ToolTip="Add Timer Trigger" Padding="6,2" Margin="0,0,4,0"/>
                            <Button Content="Remove" Command="{Binding RemoveTriggerCommand}"
                                    Padding="6,2" FontSize="11"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Triggers}"
                                 SelectedItem="{Binding SelectedTrigger}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6,4" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock FontSize="10" Foreground="Gray">
                                                <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding IsEnabled, Mode=OneWay, StringFormat='Enabled: {0}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </GroupBox>

                <!-- Variables -->
                <GroupBox Grid.Row="1" Header="Variables" Margin="4,0,4,8" MaxHeight="200">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                            <Button Content="+" Command="{Binding AddVariableCommand}"
                                    ToolTip="Add Variable" Padding="6,2" Margin="0,0,4,0"/>
                            <Button Content="Remove" Command="{Binding RemoveVariableCommand}"
                                    Padding="6,2" FontSize="11"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Variables}"
                                  SelectedItem="{Binding SelectedVariable}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  BorderBrush="#E0E0E0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Property Editor -->
            <GroupBox Grid.Column="4" Header="Properties" Margin="8">
                <Grid>
                    <ContentControl Content="{Binding SelectedAction}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAction}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                    <ContentControl Content="{Binding SelectedTrigger}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAction}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Log Panel -->
        <Border Grid.Row="4" Margin="8,0,8,4" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4"
                Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}">
            <Grid MinHeight="140" MaxHeight="250">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log Panel Header -->
                <DockPanel Background="#F5F5F5" Margin="0">
                    <TextBlock Text="Execution History" FontWeight="SemiBold" Margin="8,4"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <Button Content="Clear" Command="{Binding ClearHistoryCommand}"
                            DockPanel.Dock="Right" Padding="8,2" Margin="4" FontSize="11"
                            HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Log Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Execution Runs List -->
                    <ListBox ItemsSource="{Binding ExecutionHistory}"
                             SelectedItem="{Binding SelectedExecution}"
                             BorderThickness="0,0,1,0" BorderBrush="#E0E0E0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,2">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontSize="11" Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Result}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="Failed">
                                                            <Setter Property="Foreground" Value="#f44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Result}" Value="Cancelled">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding ResultIcon, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding StartTimeText}" FontSize="11" FontFamily="Consolas"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="Gray"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="Transparent"/>

                    <!-- Log Entries -->
                    <ListView Grid.Column="2" ItemsSource="{Binding SelectedExecution.Entries}"
                              BorderThickness="0" FontSize="11" FontFamily="Consolas">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="90"
                                    DisplayMemberBinding="{Binding TimestampText}"/>
                                <GridViewColumn Header="Level" Width="55">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Level}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Gray"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#f44336"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Info">
                                                                <Setter Property="Foreground" Value="#2196F3"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Message" Width="500"
                                    DisplayMemberBinding="{Binding Message}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Workflow:"/>
                    <Run Text="{Binding WorkflowName}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Start: " Foreground="Gray"/>
                    <TextBlock Text="{Binding StartHotkey.DisplayText}" FontFamily="Consolas" Margin="0,0,12,0"/>
                    <TextBlock Text="Stop: " Foreground="Gray"
                               Visibility="{Binding ShowSeparateStopHotkey, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StopHotkey.DisplayText}" FontFamily="Consolas"
                               Visibility="{Binding ShowSeparateStopHotkey, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
